PORT=3000

# x402 pricing
X402_PRICE_USD=0.001
X402_PAYMENT_HEADER_NAME=x402-payment

# Comma-separated valid tokens for simple header-based payment validation fallback.
# Useful for local testing or if @lucid-agents/payments verifier is not configured.
X402_VALID_TOKENS=demo-valid-payment
X402_TEST_TOKEN=demo-valid-payment

# Free sentiment API provider configuration
# Example provider domain: meaningcloud.com
# Set the full API endpoint path your provider requires.
SENTIMENT_API_ENDPOINT=
SENTIMENT_API_KEY=
SENTIMENT_API_LANG=en