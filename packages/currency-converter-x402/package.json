{
  "name": "@lucid-agents/currency-converter-x402",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lucid Agent that converts currencies using frankfurter.app and enforces x402 payment ($0.001 per lookup).",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lucid-agents/http": "workspace:*",
    "@lucid-agents/payments": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}