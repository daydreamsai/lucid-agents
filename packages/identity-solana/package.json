{
  "name": "@lucid-agents/identity-solana",
  "version": "0.1.0",
  "description": "Solana identity for Lucid SDK - ERC-8004 equivalent for Solana",
  "repository": {
    "type": "git",
    "url": "https://github.com/daydreamsai/lucid-agents",
    "directory": "packages/identity-solana"
  },
  "type": "module",
  "main": "./dist/index.js",
