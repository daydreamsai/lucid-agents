{
  "name": "@lucid-agents/identity-solana",
  "version": "0.1.0",
  "description": "8004-Solana identity helpers for Lucid agent kit surfaces",
  "repository": {
    "type": "git",
    "url": "https://github.com/daydreamsai/lucid-agents",
    "directory": "packages/identity-solana"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lucid-agents/types": "workspace:*",
    "8004-solana": "^0.7.9"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.98.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^1.98.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "@lucid-agents/eslint-config": "workspace:*",
    "@lucid-agents/prettier-config": "workspace:*",
    "@types/node": "^22.0.0"
  }
}
