PORT=3000
HOST=0.0.0.0

# x402 pricing config
X402_PRICE_USD=0.001
X402_NETWORK=base
X402_PAY_TO=

# Optional local/dev fallback token if your payments verifier is not configured yet.
# Send this value in x402-payment header for successful paid requests.
X402_DEV_TOKEN=dev_paid_token

# Stock data behavior
STOCK_CACHE_TTL_MS=5000
STOCK_REQUEST_TIMEOUT_MS=10000